        body { margin: 0; background: #1a1a1a; color: #eee; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; overflow-x: hidden; }
        #gameCanvas { background: #333; display: block; margin: 20px auto; border: 4px solid #555; touch-action: none; max-width: 95%; height: auto; cursor: pointer; }
        .article-container { max-width: 800px; margin: 20px auto; padding: 20px; text-align: left; line-height: 1.6; background: #222; border-radius: 8px; }
        h1, h2 { color: #ffcc00; }
